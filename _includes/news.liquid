<div class="news">
  {% if site.news != blank %}
    <!-- Simple Search Bar -->
    <div class="search-container" style="margin-bottom: 2rem;">
      <input
        type="text"
        id="newsSearchInput"
        onkeyup="filterNews()"
        placeholder="Search news titles or content..."
        style="width: 100%; padding: 12px 15px; border: 1px solid var(--global-divider-color); border-radius: 8px; font-size: 1rem; background-color: var(--global-bg-color); color: var(--global-text-color); outline: none; transition: border-color 0.2s;"
      >
    </div>

    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table id="news-table" class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr class="news-item">
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td class="news-content">
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>

    <!-- Live Filter Script -->
    <script>
      function filterNews() {
        var input = document.getElementById('newsSearchInput');
        var filter = input.value.toLowerCase();
        var table = document.getElementById('news-table');
        var tr = table.getElementsByClassName('news-item');

        for (var i = 0; i < tr.length; i++) {
          var td = tr[i].getElementsByClassName('news-content')[0];
          if (td) {
            var textValue = td.textContent || td.innerText;
            if (textValue.toLowerCase().indexOf(filter) > -1) {
              tr[i].style.display = '';
            } else {
              tr[i].style.display = 'none';
            }
          }
        }
      }

      // Add focus effect via JS for better integration with theme variables
      document.getElementById('newsSearchInput').addEventListener('focus', function () {
        this.style.borderColor = 'var(--global-theme-color)';
      });
      document.getElementById('newsSearchInput').addEventListener('blur', function () {
        this.style.borderColor = 'var(--global-divider-color)';
      });
    </script>

  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
