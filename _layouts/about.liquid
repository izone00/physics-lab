---
layout: default
---
<style>
  /* Global Academic Refinements */
  .lab-intro {
    font-family: 'Inter', sans-serif;
    color: var(--global-text-color);
  }
  .intro-content,
  article p,
  article li {
    font-weight: 500; /* Improved visual density */
    line-height: 1.8;
  }
  .section-block {
    margin-top: 80px !important;
    margin-bottom: 80px !important;
  }

  /* Hero Header Style - Light Gray Background */
  .hero-section {
    background-color: #f8fafc;
    margin: -2rem -15px 60px -15px; /* Increased bottom margin to 60px */
    padding: 60px 2rem;
    border-bottom: 1px solid var(--global-divider-color);
  }
  .hero-container {
    max-width: 930px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 15px; /* Reduced gap for unified brand look */
  }
  .hero-logo {
    height: 70px;
    width: auto;
    object-fit: contain;
    /* Remove dark filters, use multiply to make white background transparent */
    mix-blend-mode: multiply;
  }
  .hero-titles h1 {
    color: var(--global-theme-color);
    font-family: 'Merriweather', serif;
    font-weight: 700;
    font-size: 2.6rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
  }
  .hero-titles h2 {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--global-text-color-light);
    margin: 0;
  }

  /* News List with Dividers */
  .news-container table tr {
    border-bottom: 1px solid var(--global-divider-color);
  }
  .news-container table tr:last-child {
    border-bottom: none;
  }
  .news-container table td {
    padding: 1.2rem 0 !important;
  }

  /* Dark Mode Overrides */
  html[data-theme='dark'] .hero-section {
    background-color: rgba(255, 255, 255, 0.03);
  }
</style>

<div class="lab-intro">
  <div class="hero-section">
    <div class="hero-container">
      {% assign symbol_path = '/assets/img/yonsei_symbol.jpg' %}
      <img src="{{ symbol_path | relative_url }}" alt="Yonsei Logo" class="hero-logo">
      <div class="hero-titles">
        <h1>{{ site.lab_name | default: site.title }}</h1>
        <h2>{{ page.subtitle }}</h2>
      </div>
    </div>
  </div>

  <article>
    <!-- Main Intro Content -->
    <div class="intro-content" style="font-size: 1.15rem; margin-bottom: 3.5rem;">
      {{ content }}
    </div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <div class="section-block">
        <h3 style="color: var(--global-theme-color); font-family: 'Merriweather', serif; font-size: 1.6rem; border-bottom: 2px solid var(--global-theme-color); padding-bottom: 0.5rem; margin-bottom: 2rem; display: inline-block;">
          <a href="{{ '/news/' | relative_url }}" style="color: inherit; text-decoration: none;">Latest News</a>
        </h3>
        <div class="news-container">
          {% include news.liquid limit=true %}
        </div>
      </div>
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <div class="section-block">
        <h3 style="color: var(--global-theme-color); font-family: 'Merriweather', serif; font-size: 1.6rem; border-bottom: 2px solid var(--global-theme-color); padding-bottom: 0.5rem; margin-bottom: 2rem; display: inline-block;">
          <a href="{{ '/publications/' | relative_url }}" style="color: inherit; text-decoration: none;">Selected Publications</a>
        </h3>
        <div class="papers-container">
          {% include selected_papers.liquid %}
        </div>
      </div>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social" style="text-align: center; border-top: 1px solid var(--global-divider-color); margin-top: 5rem; padding-top: 3rem;">
        <div class="contact-icons">{% social_links %}</div>
        <div class="contact-note" style="margin-top: 1rem; color: var(--global-text-color-light);">{{ site.contact_note }}</div>
      </div>
    {% endif %}
  </article>
</div>
